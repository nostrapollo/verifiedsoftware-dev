---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Blog — Verified Software"
  description="Articles on formal verification, AI-driven theorem proving, and the emerging verified software stack."
>
  <section class="pt-32 pb-24 px-6">
    <div class="max-w-[700px] mx-auto">
      <span class="font-mono text-xs uppercase tracking-widest text-accent mb-4 block fade-up">Blog</span>
      <h1 class="font-serif text-4xl md:text-5xl mb-12 fade-up">Latest writing</h1>

      {posts.length === 0 && (
        <p class="text-text-secondary fade-up">No posts yet. Check back soon.</p>
      )}

      <div class="space-y-8">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="block group fade-up">
            <div class="flex items-baseline gap-4">
              <time class="text-text-muted text-sm font-mono shrink-0">
                {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <div>
                <h2 class="font-serif text-xl text-text-primary group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-text-secondary text-sm mt-1">{post.data.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
