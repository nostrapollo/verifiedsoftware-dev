const projects = [
  {
    name: 'Lean FRO',
    description: 'Core platform, 12+ years development, 8,000+ GitHub repos. The foundation of the verified software ecosystem.',
    link: 'https://lean-lang.org',
  },
  {
    name: 'LeanDojo / Caltech',
    description: 'AI-driven theorem proving. LeanAgent automates proof generation. TorchLean brings verified neural networks.',
    link: 'https://leandojo.org',
  },
  {
    name: 'AWS Cedar',
    description: 'Verified authorization policy engine. Production-grade, formally verified access control at scale.',
    link: 'https://www.cedarpolicy.com',
  },
  {
    name: 'Microsoft SymCrypt',
    description: 'Verifying core cryptographic library in Lean. Machine-checked proofs for the crypto that powers Azure.',
    link: 'https://github.com/microsoft/SymCrypt',
  },
  {
    name: 'AlphaProof / DeepMind',
    description: 'IMO silver medal via AI. Discovery-to-verified-proof pipeline pushing the frontier of automated reasoning.',
    link: 'https://deepmind.google/discover/blog/ai-solves-imo-problems-at-silver-medal-level/',
