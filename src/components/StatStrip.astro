---
const stats = [
  { value: '$2.41T', label: 'Annual cost of poor software quality (US)' },
  { value: '200K+', label: 'Formalized theorems in Lean\'s Mathlib' },
  { value: '47%', label: 'AI-generated code failing security tests' },
  { value: '1', label: 'Proof needed to cover every possible input' },
];
---

<section class="bg-surface border-y border-border py-16 px-6 fade-up">
  <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
    {stats.map(stat => (
      <div class="text-center">
        <div class="font-serif text-3xl md:text-4xl text-accent mb-2">{stat.value}</div>
        <div class="text-text-secondary text-sm leading-snug">{stat.label}</div>
      </div>
    ))}
  </div>
</section>
